{
  "name": "golden-aura",
  "private": true,
  "workspaces": [
    "app",
    "e2e"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "npm run dev -w app",
    "build": "npm run build -w app",
    "lint": "npm run lint -w app",
    "format": "npm run format -w app",
    "typecheck": "npm run typecheck -w app && npm run typecheck -w e2e",
    "test": "npm run test -w app",
    "test:e2e": "npm run test:e2e -w e2e",
    "test:a11y": "npm run test:a11y -w e2e",
    "test:lighthouse": "lhci autorun --config=lighthouserc.json"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1"
  },
  "overrides": {
    "playwright-core": "1.60.0"
  }
}
